# 이 파일을 .env 로 복사하고 값을 채운다. (.env 는 git 에 올라가지 않음)
# 키/토큰은 절대 config.yaml 에 직접 적지 말고 여기(.env)에 둔다.

# --- LLM (공지 문구 생성). 쓰는 제공자 것만 채우면 됨 ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- OBS WebSocket ---
OBS_PASSWORD=

# --- 디스코드 봇 ---
DISCORD_BOT_TOKEN=

# --- 트위치 채팅 (IRC) ---
# oauth 토큰은 https://twitchapps.com/tmi/ 또는 dev 콘솔에서 발급 ("oauth:" 접두어 포함)
# 토큰 없이도 익명 읽기 가능(채널만 있으면 됨)
TWITCH_OAUTH_TOKEN=
TWITCH_NICK=
TWITCH_CHANNEL=

# --- 유튜브 라이브 (pytchat) ---
# 라이브 영상 ID(매 방송 바뀜). config chat.youtube.video_id 로도 가능
YOUTUBE_VIDEO_ID=

# --- SOOP(아프리카TV) ---
SOOP_BJ_ID=

# --- Kick (익명 읽기 가능, 토큰 불필요) ---
KICK_CHANNEL=

# --- 트위캐스팅 (공식 API, OAuth2 토큰 필요) ---
# 앱 등록: https://twitcasting.tv/developer.php
TWITCASTING_USER_ID=
TWITCASTING_ACCESS_TOKEN=

# --- 네이버 카페 공식 오픈 API (OAuth2) ---
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_ACCESS_TOKEN=
NAVER_REFRESH_TOKEN=

# --- 치지직(chzzk) (선택) ---
CHZZK_CHANNEL_ID=
